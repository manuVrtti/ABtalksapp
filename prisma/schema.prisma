generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== Auth.js required models =====

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String? // Dev-mode only, plaintext. Null for OAuth users.
  role          Role      @default(STUDENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  studentProfile    StudentProfile?
  enrollments       Enrollment[]
  submissions       Submission[]
  quizAttempts      QuizAttempt[]
  referralsSent     Referral[]      @relation("Referrer")
  referralsReceived Referral[]      @relation("Referred")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===== ABtalks domain models =====

enum Role {
  STUDENT
  ADMIN
}

enum Domain {
  SE
  ML
  AI
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum SubmissionStatus {
  ON_TIME
  LATE
}

model StudentProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  fullName            String
  college             String
  graduationYear      Int
  domain              Domain
  skills              String[] @default([])
  resumeUrl           String?
  linkedinUrl         String?
  githubUsername      String?
  referralCode        String   @unique
  isReadyForInterview Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Challenge {
  id          String   @id @default(cuid())
  domain      Domain   @unique
  title       String
  description String
  totalDays   Int      @default(60)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  dailyTasks  DailyTask[]
  enrollments Enrollment[]
  quizzes     Quiz[]
}

model DailyTask {
  id                 String   @id @default(cuid())
  challengeId        String
  dayNumber          Int
  domain             Domain
  title              String
  problemStatement   String   @db.Text
  learningObjectives String[] @default([])
  resources          String[] @default([])
  difficulty         String // "Easy" | "Medium" | "Hard"
  estimatedMinutes   Int
  linkedinTemplate   String   @db.Text
  solutionApproach   String?  @db.Text
  tags               String[] @default([])
  createdAt          DateTime @default(now())

  challenge   Challenge    @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@unique([challengeId, dayNumber])
  @@index([domain, dayNumber])
}

model Enrollment {
  id               String           @id @default(cuid())
  userId           String
  challengeId      String
  domain           Domain
  status           EnrollmentStatus @default(ACTIVE)
  startedAt        DateTime         @default(now())
  completedAt      DateTime?
  daysCompleted    Int              @default(0)
  currentStreak    Int              @default(0)
  longestStreak    Int              @default(0)
  lastSubmittedDay Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge    @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@unique([userId, challengeId])
  @@index([domain, daysCompleted, currentStreak])
}

model Submission {
  id           String           @id @default(cuid())
  userId       String
  enrollmentId String
  dailyTaskId  String
  dayNumber    Int
  githubUrl    String           @unique
  linkedinUrl  String
  status       SubmissionStatus
  submittedAt  DateTime         @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  dailyTask  DailyTask  @relation(fields: [dailyTaskId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, dayNumber])
  @@index([userId])
  @@index([dayNumber])
}

model Quiz {
  id          String   @id @default(cuid())
  challengeId String
  domain      Domain
  weekNumber  Int // 1-8
  title       String
  createdAt   DateTime @default(now())

  challenge Challenge      @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@unique([challengeId, weekNumber])
}

model QuizQuestion {
  id            String @id @default(cuid())
  quizId        String
  questionOrder Int
  questionText  String @db.Text
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String // "A" | "B" | "C" | "D"
  explanation   String @db.Text

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, questionOrder])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  score       Int // out of 10
  answers     Json // stored as { "1": "A", "2": "C", ... }
  attemptedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
  @@index([userId])
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referredId  String   @unique
  rewardGiven Boolean  @default(false)
  createdAt   DateTime @default(now())

  referrer User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}
